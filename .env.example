# Copy to ".env" and fill in. Do NOT commit the real .env.

# Shared secret the Worker must send as "Authorization: Bearer <token>" when it
# POSTs to /ingest. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INGEST_TOKEN=replace-with-a-long-random-secret

# Login for the dashboard + read APIs (Basic Auth). The /ingest endpoint is NOT
# behind this — it uses INGEST_TOKEN — so the Worker still works.
DASH_USER=admin
DASH_PASS=replace-with-a-dashboard-password

# Dedicated DuckDNS hostname JUST for the logs. Create it in your DuckDNS
# account (a separate name from the Home Assistant one) so the ACME DNS-01
# challenge doesn't clash with the HA DuckDNS add-on. Point it at your home IP.
LOG_DOMAIN=wisenerlogs.duckdns.org

# External/internal HTTPS port Caddy serves on. Forward THIS port on your router
# to the NUC. The Worker will POST to https://${LOG_DOMAIN}:${LOG_PORT}/ingest.
LOG_PORT=9443

# DuckDNS API token — the same token your HA DuckDNS add-on uses (find it on the
# DuckDNS account page). Used only for the cert's DNS-01 challenge.
DUCKDNS_TOKEN=replace-with-your-duckdns-token

# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=david.wisener@gmail.com

# Delete events older than this many days (0 = keep forever).
RETAIN_DAYS=30
