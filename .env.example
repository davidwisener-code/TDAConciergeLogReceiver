# Copy to ".env" and fill in. Do NOT commit the real .env.

# Shared secret the Worker must send as "Authorization: Bearer <token>" when it
# POSTs to /ingest. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INGEST_TOKEN=replace-with-a-long-random-secret

# Login for the dashboard + read APIs (Basic Auth). The /ingest endpoint is NOT
# behind this — it uses INGEST_TOKEN — so the Worker still works.
DASH_USER=admin
DASH_PASS=replace-with-a-dashboard-password

# Public hostname Caddy serves HTTPS on. Your DuckDNS name (must resolve to your
# home IP, with router ports 80+443 forwarded to this NUC).
LOG_DOMAIN=wisener.duckdns.org

# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=david.wisener@gmail.com

# Delete events older than this many days (0 = keep forever).
RETAIN_DAYS=30
