# Caddy reverse proxy for the log receiver, on a custom HTTPS port.
#
# Values come from the environment (set in .env via docker-compose):
#   LOG_DOMAIN     dedicated DuckDNS hostname for logs (e.g. wisenerlogs.duckdns.org)
#   LOG_PORT       external/internal HTTPS port (e.g. 9443)
#   ACME_EMAIL     Let's Encrypt contact
#   DUCKDNS_TOKEN  DuckDNS API token (used for the ACME DNS-01 challenge)
#
# The cert is obtained/renewed via the DuckDNS DNS-01 challenge, so NO inbound
# port 80 is required — only LOG_PORT needs to be forwarded to this NUC.

{
	email {$ACME_EMAIL}
}

{$LOG_DOMAIN}:{$LOG_PORT} {
	tls {
		dns duckdns {$DUCKDNS_TOKEN}
		# Use public resolvers for the DNS-01 challenge — the container's
		# default resolver can return SERVFAIL on the zone lookup.
		resolvers 1.1.1.1 8.8.8.8
	}
	encode gzip
	reverse_proxy log-receiver:8080
}
