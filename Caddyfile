# Caddy reverse proxy for the log receiver.
#
# {$LOG_DOMAIN} and {$ACME_EMAIL} are read from the environment (set in .env via
# docker-compose). Caddy automatically obtains and renews a Let's Encrypt cert
# for the hostname using the HTTP-01 challenge — which is why port 80 must be
# forwarded to this NUC. All traffic is proxied to the log-receiver container.

{
	email {$ACME_EMAIL}
}

{$LOG_DOMAIN} {
	encode gzip
	reverse_proxy log-receiver:8080
}
